# ================================================================
# Variables de entorno – Blueprints Frontend (Vite)
# ================================================================
# Copiar como .env en la raíz del proyecto LAB06.

# URL base del API REST (el apiClient.js la usa como baseURL)
VITE_API_BASE_URL=http://localhost:8080/api

# Conmutador de servicios:
#   true  → apimock (datos en memoria, no necesita backend corriendo)
#   false → apiclientService (API REST real, requiere JWT válido)
VITE_USE_MOCK=true
